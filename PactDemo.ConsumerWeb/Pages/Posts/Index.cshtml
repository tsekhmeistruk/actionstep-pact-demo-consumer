@page "/posts"
@model PactDemo.ConsumerWeb.Pages.Posts.IndexModel
@{
    ViewData["Title"] = "Posts";
}

<div class="pb-3">
    <h1 class="display-6 mb-1">Posts</h1>
    <p class="text-muted mb-0">All posts loaded from the provider API.</p>
</div>

@if (Model.ErrorMessage is not null)
{
    <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
}
else if (Model.Posts.Count == 0)
{
    <div class="alert alert-info" role="alert">No posts found.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead>
                <tr>
                    <th scope="col" style="width: 80px;">Id</th>
                    <th scope="col">Title</th>
                    <th scope="col" style="width: 120px;">User Id</th>
                    <th scope="col" style="width: 120px;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var post in Model.Posts)
                {
                    <tr>
                        <td>@post.Id</td>
                        <td>@post.Title</td>
                        <td><span class="badge text-bg-light">@post.UserId</span></td>
                        <td>
                            <a class="btn btn-sm btn-outline-primary"
                               asp-page="/Posts/Details"
                               asp-route-id="@post.Id">Details</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
