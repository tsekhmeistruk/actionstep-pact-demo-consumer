@page "/posts/{id}"
@model PactDemo.ConsumerWeb.Pages.Posts.DetailsModel
@{
    ViewData["Title"] = Model.Post?.Title ?? "Post";
}

<div class="pb-3">
    <a class="btn btn-sm btn-outline-secondary" asp-page="/Posts/Index">&larr; Back to posts</a>
</div>

@if (Model.ErrorMessage is not null)
{
    <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
}
else if (Model.PostNotFound)
{
    <div class="alert alert-warning" role="alert">Post <strong>@Model.Id</strong> was not found.</div>
}
else if (Model.Post is { } post)
{
    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <h2 class="card-title h4">@post.Title</h2>
            <h6 class="card-subtitle text-muted mb-3">Post #@post.Id &middot; by user @post.UserId</h6>
            <p class="card-text">@post.Body</p>
        </div>
    </div>

    <h3 class="h5 mb-3">Comments <span class="badge text-bg-secondary">@Model.Comments.Count</span></h3>

    @if (Model.Comments.Count == 0)
    {
        <div class="alert alert-info" role="alert">No comments yet.</div>
    }
    else
    {
        <ul class="list-group">
            @foreach (var comment in Model.Comments)
            {
                <li class="list-group-item">
                    <div class="d-flex justify-content-between align-items-start mb-1">
                        <strong>@comment.Name</strong>
                        <span class="text-muted small">@comment.Email</span>
                    </div>
                    <p class="mb-0">@comment.Body</p>
                </li>
            }
        </ul>
    }
}
